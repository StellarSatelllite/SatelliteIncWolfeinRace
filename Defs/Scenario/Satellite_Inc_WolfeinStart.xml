<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <!-- 飞船事故 -->
    <ScenarioDef ParentName="ScenarioBase">
        <defName>Satellite_Inc_Wolfein_Scenarios</defName>
        <label>Satellite Inc Wolfein New start</label>
        <description>.</description>
        <scenario>
            <summary>.</summary>
            <playerFaction Inherit="false">
                <def>PlayerFaction</def>
                <factionDef>Satellite_Inc_Wolfein_PlayerFaction</factionDef>
            </playerFaction>
            <parts>

                <!-- 开局人数 -->
                <li Class="ScenPart_ConfigPage_ConfigureStartingPawns">
                    <def>ConfigPage_ConfigureStartingPawns</def>
                    <pawnCount>3</pawnCount>
                    <pawnChoiceCount>8</pawnChoiceCount>
                </li>

                <li Class="ScenPart_PlayerPawnsArriveMethod">
                    <def>PlayerPawnsArriveMethod</def>
                    <method>DropPods</method>
                </li>

                <!-- 开局携带物资 -->
                <li Class="ScenPart_StartingThing_Defined">
                    <def>StartingThing_Defined</def>
                    <thingDef>Silver</thingDef>
                    <count>200</count>
                </li>
                <li Class="ScenPart_StartingThing_Defined">
                    <def>StartingThing_Defined</def>
                    <thingDef>W_Weapon_HG_Pistol</thingDef>
                </li>
                <li Class="ScenPart_StartingThing_Defined">
                    <def>StartingThing_Defined</def>
                    <thingDef>W_Weapon_Melee_AlloyDagger</thingDef>
                    <stuff>Wolfein_AlloyMaterials</stuff>
                </li>
                <li Class="ScenPart_StartingThing_Defined">
                    <def>StartingThing_Defined</def>
                    <thingDef>MedicineIndustrial</thingDef>
                    <count>20</count>
                </li>
                <li Class="ScenPart_StartingThing_Defined">
                    <def>StartingThing_Defined</def>
                    <thingDef>ComponentIndustrial</thingDef>
                    <count>25</count>
                </li>
                <li Class="ScenPart_StartingThing_Defined">
                    <def>StartingThing_Defined</def>
                    <thingDef>Wolfein_PackingStaffMeals</thingDef>
                    <count>60</count>
                </li>
                <li Class="ScenPart_StartingThing_Defined">
                    <def>StartingThing_Defined</def>
                    <thingDef>Wolfein_FlakJacket</thingDef>
                </li>

                <li Class="ScenPart_ScatterThingsNearPlayerStart">
                    <def>ScatterThingsNearPlayerStart</def>
                    <thingDef>WoodLog</thingDef>
                    <count>400</count>
                </li>
                <li Class="ScenPart_ScatterThingsNearPlayerStart">
                    <def>ScatterThingsNearPlayerStart</def>
                    <thingDef>Steel</thingDef>
                    <count>300</count>
                </li>

                <!-- 开局随机散落物资 -->
                <li Class="ScenPart_ScatterThingsAnywhere">
                    <def>ScatterThingsAnywhere</def>
                    <thingDef>Steel</thingDef>
                    <count>450</count>
                </li>
                <li Class="ScenPart_ScatterThingsAnywhere">
                    <def>ScatterThingsAnywhere</def>
                    <thingDef>ShipChunk</thingDef>
                    <allowRoofed>false</allowRoofed>
                    <count>5</count>
                </li>
                <li Class="ScenPart_ScatterThingsAnywhere">
                    <def>ScatterThingsAnywhere</def>
                    <thingDef>Wolfein_PackingStaffMeals</thingDef>
                    <count>8</count>
                </li>

            </parts>
        </scenario>
    </ScenarioDef>

    <!-- 离群狼 -->
    <ScenarioDef ParentName="ScenarioBase">
        <defName>Satellite_Inc_Wolfein_OutlierWolf</defName>
        <label>Satellite Inc Wolfein Outlier Wolf</label>
        <description>.</description>
        <scenario>
            <summary>.</summary>
            <playerFaction Inherit="false">
                <def>PlayerFaction</def>
                <factionDef>Wolfein_PlayerFaction_Satellite_Inc_Hostile</factionDef>
            </playerFaction>
            <parts>

                <!-- 开局人数 -->
                <li Class="ScenPart_ConfigPage_ConfigureStartingPawns">
                    <def>ConfigPage_ConfigureStartingPawns</def>
                    <pawnCount>1</pawnCount>
                    <pawnChoiceCount>8</pawnChoiceCount>
                </li>

                <li Class="ScenPart_PlayerPawnsArriveMethod">
                    <def>PlayerPawnsArriveMethod</def>
                    <method>Standing</method>
                </li>

                <!-- 开局携带物资 -->
                <li Class="ScenPart_StartingThing_Defined">
                    <def>StartingThing_Defined</def>
                    <thingDef>Silver</thingDef>
                    <count>70</count>
                </li>
                <li Class="ScenPart_StartingThing_Defined">
                    <def>StartingThing_Defined</def>
                    <thingDef>W_Weapon_SMG_LightSubmachineGun</thingDef>
                </li>
                <li Class="ScenPart_StartingThing_Defined">
                    <def>StartingThing_Defined</def>
                    <thingDef>MedicineIndustrial</thingDef>
                    <count>5</count>
                </li>
                <li Class="ScenPart_StartingThing_Defined">
                    <def>StartingThing_Defined</def>
                    <thingDef>ComponentIndustrial</thingDef>
                    <count>15</count>
                </li>
                <li Class="ScenPart_StartingThing_Defined">
                    <def>StartingThing_Defined</def>
                    <thingDef>Wolfein_PackingStaffMeals</thingDef>
                    <count>15</count>
                </li>
                <li Class="ScenPart_ScatterThingsNearPlayerStart">
                    <def>ScatterThingsNearPlayerStart</def>
                    <thingDef>WoodLog</thingDef>
                    <count>250</count>
                </li>

                <!-- 开局随机散落物资 -->
                <li Class="ScenPart_ScatterThingsAnywhere">
                    <def>ScatterThingsAnywhere</def>
                    <thingDef>Steel</thingDef>
                    <count>200</count>
                </li>

            </parts>
        </scenario>
    </ScenarioDef>

</Defs>